{
  "name": "@dynaris/widget",
  "version": "1.0.2",
  "description": "Embeddable chat widget that connects to the Dynaris chat pipeline (web_widget channel)",
  "type": "module",
  "main": "dist/dynaris-widget.umd.cjs",
  "module": "dist/dynaris-widget.es.js",
  "types": "dynaris-widget.d.ts",
  "exports": {
    ".": {
      "types": "./dynaris-widget.d.ts",
      "import": "./dist/dynaris-widget.es.js",
      "require": "./dist/dynaris-widget.umd.cjs"
    }
  },
  "files": [
    "dist",
    "dynaris-widget.d.ts"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "devDependencies": {
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "dynaris",
    "chat",
    "widget",
    "embed"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dynaris-ai/dynaris-widget"
  },
  "packageManager": "pnpm@10.15.0"
}
