{
  "name": "@dynaris/widget",
  "version": "1.1.8",
  "description": "Embeddable chat widget that connects to the Dynaris chat pipeline (web_widget channel)",
  "type": "module",
  "main": "dist/dynaris-widget.umd.cjs",
  "module": "dist/dynaris-widget.es.js",
  "types": "dynaris-widget.d.ts",
  "exports": {
    ".": {
      "types": "./dynaris-widget.d.ts",
      "import": "./dist/dynaris-widget.es.js",
      "require": "./dist/dynaris-widget.umd.cjs"
    }
  },
  "files": [
    "dist",
    "dynaris-widget.d.ts"
  ],
  "scripts": {
    "build": "vite build",
    "dispatch:consumers": "node scripts/notify-consumers.js",
    "dev": "vite",
    "postpublish": "pnpm dispatch:consumers",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "devDependencies": {
    "happy-dom": "^20.8.4",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "dynaris",
    "chat",
    "widget",
    "embed",
    "ai",
    "ai-agent",
    "chatbot",
    "voice-ai",
    "livekit",
    "webrtc",
    "chat-widget",
    "ai-chat",
    "conversational-ai",
    "customer-support",
    "live-chat",
    "react",
    "nextjs",
    "vanilla-js"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dynaris-ai/dynaris-widget"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.15.0",
  "dependencies": {
    "livekit-client": "^2.17.3"
  }
}
