# Copy to `.env` in this directory (repo root). Vite loads it for `pnpm dev` / playground.
# Do not commit `.env`.

VITE_CHAT_WIDGET_API_KEY=dw_your_widget_api_key_here
VITE_CHAT_WIDGET_API_URL=https://api.dynaris.ai
VITE_CHAT_WIDGET_VOICE_AGENT_ID=your-voice-agent-uuid
VITE_CHAT_WIDGET_VOICE_API_URL=https://api.dynaris.ai
VITE_WIDGET_TITLE=Dynaris Voice
VITE_WIDGET_SUBTITLE=Try our AI voice agent
